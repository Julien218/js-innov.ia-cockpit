# JS-Innov.IA Cockpit — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs réelles

# ── Agent jsinnovia-agent (Railway) ──────────────────────────────────────────
# URL du service backend Railway (proxy Supabase)
VITE_AGENT_URL=https://jsinnovia-agent-production.up.railway.app

# Clé d'auth pour x-agent-key header (même valeur que VITE_AGENT_AUTH)
VITE_AGENT_KEY=your_agent_key_here

# Alias utilisé par base44Client.js (même valeur que VITE_AGENT_KEY)
VITE_AGENT_AUTH=your_agent_key_here

# ── Page /agents-ia (Base44 Workspace API) ───────────────────────────────────
# Clé API workspace Base44 (Settings → API Keys sur app.base44.com)
VITE_BASE44_API_KEY=your_base44_workspace_api_key_here

# ── Cockpit API interne ───────────────────────────────────────────────────────
# URL du cockpit (pour les appels inter-services)
VITE_COCKPIT_API_URL=https://cockpit.jsinnovia.com

# Clé API cockpit (même que VITE_AGENT_KEY généralement)
VITE_AGENT_API_KEY=your_agent_key_here

# ── Webhook sync leads ────────────────────────────────────────────────────────
VITE_COCKPIT_WEBHOOK_URL=https://jsinnovia-agent-production.up.railway.app/webhook/leads

# ── Supabase (lecture publique uniquement — anon key) ────────────────────────
VITE_SUPABASE_URL=https://gfjpryakxzdzwnazlsfz.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Base44 App ID ─────────────────────────────────────────────────────────────
VITE_APP_ID=69ff4dc771a2cdab275f8a00
