{
  "compilerOptions": {
    "target": "ES2022", "lib": ["ES2022"], "allowJs": true, "skipLibCheck": true,
    "strict": true, "noEmit": true, "module": "ES2022", "esModuleInterop": true, "moduleResolution": "Bundler",
    "resolveJsonModule": true, "isolatedModules": true, "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
