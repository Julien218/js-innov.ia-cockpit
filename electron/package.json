{
  "name": "jsinnovia-cockpit",
  "version": "1.0.0",
  "description": "JS-Innov.IA Cockpit — Application desktop",
  "main": "main.js",
  "author": "Julien Pagin <julien@jsinnovia.com>",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jsinnovia.cockpit",
    "productName": "JS-Innov.IA Cockpit",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "installerLanguages": [
        "fr_FR"
      ],
      "language": "1036"
    }
  }
}